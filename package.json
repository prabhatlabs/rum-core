{
    "name": "rum-core",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md,html}\"",
        "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md,html}\"",
        "run:api": "bun run --cwd apps/api start",
        "run:api:dev": "bun run --cwd apps/api dev",
        "run:web": "bun run --cwd apps/web dev",
        "run:web:build": "bun run --cwd apps/web build",
        "run:web:start": "bun run --cwd apps/web start",
        "run:web:lint": "bun run --cwd apps/web lint",
        "run:worker": "bun run --cwd apps/worker dev",
        "run:worker:deploy": "bun run --cwd apps/worker deploy",
        "run:worker:cf-typegen": "bun run --cwd apps/worker cf-typegen",
        "run:db": "bun run --cwd packages/db db:studio",
        "run:db:push": "bun run --cwd packages/db db:push",
        "run:db:generate": "bun run --cwd packages/db db:generate",
        "run:db:migrate": "bun run --cwd packages/db db:migrate",
        "run:db:pull": "bun run --cwd packages/db db:pull",
        "run:db:studio:eventdb": "bun run --cwd packages/db db:studio:eventdb",
        "run:db:push:eventdb": "bun run --cwd packages/db db:push:eventdb",
        "run:db:generate:eventdb": "bun run --cwd packages/db db:generate:eventdb",
        "run:db:migrate:eventdb": "bun run --cwd packages/db db:migrate:eventdb",
        "build:script": "bun run --cwd packages/script build",
        "docker:build": "docker build -t rum-core .",
        "docker:run": "docker run -p 8000:8000 rum-core"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "devDependencies": {
        "@types/bun": "latest"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@upstash/redis": "^1.37.0"
    }
}
