{
  "name": "rum-core",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build:script": "bun run --cwd packages/script build",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md,html}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md,html}\"",
    "docker:build": "docker build -t rum-core .",
    "docker:rum": "docker run rum-core"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}